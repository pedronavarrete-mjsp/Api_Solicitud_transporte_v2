# No subir `.env` al repositorio; usar solamente en archivo `.env` local


# -------- MongoDB Database --------
# Opción 1: Usar DB_URL directamente (tiene prioridad si existe)
# DB_URL=mongodb://admin:password123@localhost:27017/dev_oni_justicia?authSource=admin

# Opción 2: Usar variables individuales (se usarán si DB_URL no está definida)
